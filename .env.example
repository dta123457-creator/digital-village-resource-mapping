# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/village_mapping
SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/village_mapping

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Geospatial Configuration
DEFAULT_LATITUDE=20.5937
DEFAULT_LONGITUDE=78.9629
DEFAULT_ZOOM_LEVEL=13
MAP_PROVIDER=OpenStreetMap

# AI/ML Configuration
MODEL_PATH=models/
CONFIDENCE_THRESHOLD=0.7
MAX_IMAGE_SIZE=2048

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Feature Flags
ENABLE_ADVANCED_ANALYTICS=True
ENABLE_REAL_TIME_PROCESSING=False
ENABLE_3D_VISUALIZATION=False
